# Copy to .env.local and fill with your Firebase project values
# Get these from Firebase Console → Project Settings → Your apps → Web app

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# For live transfer windows (scraped from Transfermarkt), run mgsr-backend and set:
# NEXT_PUBLIC_BACKEND_URL=http://localhost:8080
# Leave unset to use built-in API routes (static fallback data).

# For document detection (passport/mandate) on player info page:
# GEMINI_API_KEY=your_gemini_api_key

# For share API (generates short scout report via Gemini when creating share):
# GEMINI_API_KEY=... (same as above)

# For share API server-side create (optional - if not set, client creates share via Firestore):
# FIREBASE_PROJECT_ID=your_project_id
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@your_project.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# Or: FIREBASE_SERVICE_ACCOUNT='{"type":"service_account",...}'

# Share link base URL (for API response). Defaults to VERCEL_URL in production.
# NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
