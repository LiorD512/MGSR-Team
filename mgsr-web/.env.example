# Copy to .env.local and fill with your Firebase project values
# Get these from Firebase Console → Project Settings → Your apps → Web app

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# For live transfer windows (scraped from Transfermarkt), run mgsr-backend and set:
# NEXT_PUBLIC_BACKEND_URL=http://localhost:8080
# Leave unset to use built-in API routes (static fallback data).

# For document detection (passport/mandate) on player info page:
# GEMINI_API_KEY=your_gemini_api_key

# For share API (generates short scout report via Gemini when creating share):
# GEMINI_API_KEY=... (same as above)

# For share API server-side create (optional - if not set, client creates share via Firestore):
# FIREBASE_PROJECT_ID=your_project_id
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@your_project.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# Or: FIREBASE_SERVICE_ACCOUNT='{"type":"service_account",...}'

# Share link base URL (for API response). Defaults to VERCEL_URL in production.
# NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Google Calendar sync (for task sync on /tasks page)
# Get from Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs
# NEXT_PUBLIC_GOOGLE_CALENDAR_CLIENT_ID=your_client_id.apps.googleusercontent.com

# YouTube Data API v3 key — for player highlight videos on player info page
# Get from: https://console.cloud.google.com/ → Enable YouTube Data API v3 → Create API key
# YOUTUBE_API_KEY=your_youtube_api_key

# IFA (football.org.il) — when direct fetch returns 403, app tries:
# 1. AllOrigins free proxy (no config)
# 2. football-scout-server /ifa/fetch-profile (if SCOUT_SERVER_URL set — add docs/ifa_fetch_for_scout_server.py)

# Women players — image search (player name + soccer). Optional.
# SerpAPI (recommended): Free 100 searches/month. Sign up at https://serpapi.com/
# SERPAPI_KEY=your_serpapi_key
#
# Google Custom Search (deprecated for new projects — may not work):
# GOOGLE_CSE_API_KEY=your_api_key
# GOOGLE_CSE_CX=your_search_engine_id

# Women players search (Wosostat API) — optional; if unset, search returns empty
# Get token from https://wosoapi.onrender.com/ (register, verify email, POST /api/token/)
# WOSOAPI_TOKEN=your_jwt_token
# Or use email+password to fetch token:
# WOSOAPI_EMAIL=your@email.com
# WOSOAPI_PASSWORD=your_password
