<?xml version="1.0" encoding="utf-8"?>
<!-- Radial gradient: subtle teal glow at center -> dashboard dark (#0F1923). Oval = circle when bounds are square. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="oval">
    <gradient
        android:type="radial"
        android:gradientRadius="300dp"
        android:centerX="0.5"
        android:centerY="0.5"
        android:startColor="#1F4DB6AC"
        android:endColor="#0F1923" />
</shape>
