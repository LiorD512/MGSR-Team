<?xml version="1.0" encoding="utf-8"?>
<!-- Radial glow: soft teal center, subtle blue mid-tone, fades to dark. Concentrated behind logo. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="oval">
    <gradient
        android:type="radial"
        android:gradientRadius="180dp"
        android:centerX="0.5"
        android:centerY="0.5"
        android:startColor="#404DB6AC"
        android:centerColor="#1A42A5F5"
        android:endColor="#0F1923" />
</shape>
