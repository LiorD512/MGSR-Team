<?xml version="1.0" encoding="utf-8"?>
<!-- Splash icon: radial gradient (dashboard-style) + logo. Square bounds force circular gradient on all devices. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item
        android:drawable="@drawable/splash_gradient_bg"
        android:width="288dp"
        android:height="288dp"
        android:gravity="center" />
    <item
        android:drawable="@drawable/for_app_logo"
        android:width="56dp"
        android:height="56dp"
        android:gravity="center"
        android:left="40dp"
        android:right="40dp"
        android:top="40dp"
        android:bottom="40dp" />
</layer-list>
