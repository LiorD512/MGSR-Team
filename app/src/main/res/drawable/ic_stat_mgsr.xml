<?xml version="1.0" encoding="utf-8"?>
<!-- Notification small icon — three ascending MGSR brand-mark bars.
     White-on-transparent (alpha-only): the system renders white on dark
     status bars and dark on light status bars automatically.
     NO circle background — that causes a solid white blob. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">

    <!-- Short bar (left) -->
    <path
        android:pathData="M1,22 L6,13 L9,13 L9,22 Z"
        android:fillColor="#FFFFFF"/>

    <!-- Medium bar (centre) -->
    <path
        android:pathData="M10,22 L15.5,5 L18.5,5 L18.5,22 Z"
        android:fillColor="#FFFFFF"/>

    <!-- Tall bar (right) -->
    <path
        android:pathData="M19.5,22 L23,2 L24,2 L24,22 Z"
        android:fillColor="#FFFFFF"/>
</vector>
