<?xml version="1.0" encoding="utf-8"?>
<!-- Notification small icon — MGSR ascending-bars brand mark.
     White-on-transparent: Android uses the alpha channel only and
     tints with the accent colour set via setColor(). -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">

    <!-- Small bar (left) -->
    <path
        android:pathData="M2,20 L4,14 L6,14 L6,20 Z"
        android:fillColor="#FFFFFF"/>

    <!-- Medium bar (centre) -->
    <path
        android:pathData="M8,20 L11,9 L13,9 L13,20 Z"
        android:fillColor="#FFFFFF"/>

    <!-- Tall bar (right) -->
    <path
        android:pathData="M15,20 L20,3 L22,3 L22,20 Z"
        android:fillColor="#FFFFFF"/>
</vector>
