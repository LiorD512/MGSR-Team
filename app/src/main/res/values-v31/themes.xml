<?xml version="1.0" encoding="utf-8"?>
<!-- API 31+: Gradient splash — system applies circular mask, so gradient always appears circular -->
<resources>
    <style name="Theme.MGSRTeam.Splash" parent="Theme.SplashScreen">
        <item name="android:windowSplashScreenBackground">#0F1923</item>
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/splash_icon_gradient</item>
        <item name="postSplashScreenTheme">@style/Theme.MGSRTeam</item>
    </style>
</resources>
