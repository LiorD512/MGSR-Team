<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.MGSRTeam" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="android:windowBackground">#0F1923</item>
    </style>

    <!-- Splash theme: Logo only on pre-API 31 (no gradient — avoids square/circle inconsistency) -->
    <style name="Theme.MGSRTeam.Splash" parent="Theme.SplashScreen">
        <item name="android:windowSplashScreenBackground">#0F1923</item>
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/splash_icon_ocean</item>
        <item name="postSplashScreenTheme">@style/Theme.MGSRTeam</item>
    </style>
</resources>