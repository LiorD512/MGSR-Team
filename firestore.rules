rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // SharedPlayers: public read (token is unguessable), create requires auth
    match /SharedPlayers/{token} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }
    // Players: read/write for authenticated users (pinnedHighlights, etc.)
    match /Players/{playerId} {
      allow read, write: if request.auth != null;
    }
    // Portfolio: per-agent collection, authenticated read/write
    match /Portfolio/{docId} {
      allow read, write: if request.auth != null;
    }
    // ScoutProfiles: AI Scout Agent Network — read for authenticated, write by backend/jobs only
    match /ScoutProfiles/{profileId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    // ScoutAgentRuns: run history — read for authenticated
    match /ScoutAgentRuns/{runId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ── Core app collections (required for dashboard, tasks, etc.) ──
    match /Accounts/{docId} {
      allow read, write: if request.auth != null;
    }
    match /AgentTasks/{docId} {
      allow read, write: if request.auth != null;
    }
    match /FeedEvents/{docId} {
      allow read, write: if request.auth != null;
    }
    match /ClubRequests/{docId} {
      allow read, write: if request.auth != null;
    }
    match /Contacts/{docId} {
      allow read, write: if request.auth != null;
    }
    match /Shortlists/{docId} {
      allow read, write: if request.auth != null;
    }
    match /PlayerDocuments/{docId} {
      allow read, write: if request.auth != null;
    }
    match /PlayerOffers/{docId} {
      allow read, write: if request.auth != null;
    }
    match /ShadowTeams/{docId} {
      allow read, write: if request.auth != null;
    }

    // Reference/lookup collections (read for app, write by admin/backend)
    match /Sections/{docId} { allow read: if request.auth != null; allow write: if request.auth != null; }
    match /Strengths/{docId} { allow read: if request.auth != null; allow write: if request.auth != null; }
    match /DocumentsType/{docId} { allow read: if request.auth != null; allow write: if request.auth != null; }
    match /Leagues/{docId} { allow read: if request.auth != null; allow write: if request.auth != null; }
    match /Clubs/{docId} { allow read: if request.auth != null; allow write: if request.auth != null; }
    match /Positions/{docId} { allow read: if request.auth != null; allow write: if request.auth != null; }
    match /Roles/{docId} { allow read: if request.auth != null; allow write: if request.auth != null; }
    match /Requests/{docId} { allow read: if request.auth != null; allow write: if request.auth != null; }
    match /YouthPlayers/{docId} { allow read: if request.auth != null; allow write: if request.auth != null; }
    match /YouthStatus/{docId} { allow read: if request.auth != null; allow write: if request.auth != null; }
  }
}
