rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // ChatRoom attachments — authenticated users can upload, anyone authenticated can read
    match /ChatRoom/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024; // 10 MB limit
    }

    // Player documents (passports, mandates, medicals, etc.)
    match /player_docs/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 20 * 1024 * 1024; // 20 MB limit
    }

    // Default: deny all other paths (add more rules as needed)
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
